{
  "name": "use-state-multiple",
  "version": "1.0.1",
  "description": "React state hook for multiple values",
  "main": "dist/use-state-multiple.js",
  "scripts": {
    "build": "rimraf ./dist && rollup --bundleConfigAsCjs -c ./build/rollup.config.js && copyfiles README.md .npmrc .npmignore ./dist",
    "test": "mocha ./test/**/*.test.jsx ./test/*.test.jsx --require @babel/register",
    "test:coverage": "c8 --reporter=text npm run test",
    "dev": "npm test & run-when-changed --watch \"src/**/*.js\" --watch \"test/**/*.jsx\" --exec \"npm test\"",
    "dev:coverage": "npm run test:coverage & run-when-changed --watch \"src/**/*.js\" --watch \"test/**/*.jsx\" --exec \"npm run test:coverage\"",
    "version": "npm version --no-git-tag-version --"
  },
  "author": "Dmitriy A. Nesterkin",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/aptivator/use-state-multiple.git"
  },
  "bugs": {
    "url": "https://github.com/aptivator/use-state-multiple/issues"
  },
  "dependencies": {
    "core-js": "^3.40.0",
    "react": ">=16.7.0"
  },
  "devDependencies": {
    "@babel/cli": "~7.20.7",
    "@babel/core": "~7.20.7",
    "@babel/node": "~7.20.7",
    "@babel/preset-env": "~7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/register": "~7.18.9",
    "@rollup/plugin-babel": "~6.0.3",
    "c8": "^7.12.0",
    "chai": "~4.3.7",
    "copyfiles": "~2.4.1",
    "jsdom": "^22.0.0",
    "lodash.pick": "~4.4.0",
    "mocha": "~10.2.0",
    "react-dom": "^19.0.0",
    "rimraf": "^3.0.2",
    "rollup": "~3.8.0",
    "run-when-changed": "~2.1.0"
  }
}
